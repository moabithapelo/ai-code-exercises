            cache[task.id] = calculate_task_score_improved(task)
        return cache[task.id]
    
    return sorted(tasks, key=get_score, reverse=True)

def get_top_priority_tasks_with_tiebreaker(tasks, limit=5):
    """Return top tasks with tie-breaking rules."""
    sorted_tasks = sort_tasks_by_importance_with_cache(tasks)
    
    # If we have fewer tasks than limit, return all
    if len(sorted_tasks) <= limit:
        return sorted_tasks
    
    # Check if there's a tie at the cutoff
    cutoff_score = calculate_task_score_improved(sorted_tasks[limit-1])
    next_score = calculate_task_score_improved(sorted_tasks[limit])
    
    if cutoff_score == next_score:
